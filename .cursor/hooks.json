{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "./lmc hook cursor-session-start",
        "timeout": 15
      }
    ],
    "sessionEnd": [
      {
        "command": "./lmc hook cursor-session-end",
        "timeout": 10
      }
    ],
    "preCompact": [
      {
        "command": "./lmc hook cursor-pre-compact",
        "timeout": 10
      }
    ]
  }
}